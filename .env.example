# ─────────────────────────────────────────────────────────────────────────────
# sofascore-nest-api  ·  Environment variables reference
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in the values that apply to your environment.
#
# THERE ARE NO TOURNAMENT IDs HERE — they are never hardcoded.
# On every startup TournamentRegistryService calls the provider's
#   sport/{sport}/categories/all
# endpoint and upserts every discovered tournament into the DB automatically.
# The same refresh runs nightly. You control which tournaments are active via
# the /admin/registry API, not env files.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Your database. docker-compose in this repo spins one up for local dev.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sofascore
POSTGRES_PASSWORD=sofascore
POSTGRES_DB=sofascore
# Required for hosted Postgres providers that enforce TLS.
POSTGRES_SSL=false
# Set to false when provider uses managed certs not trusted by local CA store.
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=3000
# Set to true to print Nest’s full bootstrap INFO (every module + “Mapped … route”).
# Default is quiet: only warn/error/fatal from the framework.
# NEST_VERBOSE_BOOTSTRAP=true
# Comma-separated origins allowed for CORS (matchstat.com frontends)
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# ── External data provider ────────────────────────────────────────────────────
#
# sportsdata365 serves the same JSON shape as SofaScore under:
#   https://sportsdata365.com/football/api/v1/h2h/sports/{sofascore-path}
#
# If you see HTTP 403 on every outbound call, the provider is blocking the request.
# Typical fixes (use what your subscription actually requires):
#   1) Set PROVIDER_API_KEY (and PROVIDER_AUTH_HEADER_NAME if not x-api-key).
#      For Authorization: Bearer … put the full value in PROVIDER_API_KEY, e.g.
#      PROVIDER_API_KEY=Bearer eyJhbG…   and PROVIDER_AUTH_HEADER_NAME=Authorization
#   2) IP allowlisting — run the app from an allowed network or ask the vendor to allow your IP.
#   3) Confirm base URL and plan with whoever issued the subscription.
#   4) Org reverse proxy — if curl from your laptop is 403 but production uses nginx
#      (e.g. sofa-api-proxy) in front of the same paths, point PROVIDER_BASE_URL at
#      that proxy’s **origin** (scheme + host + path prefix that matches this app’s
#      relative paths). Local dev then hits the allowlisted hop instead of sportsdata365
#      directly. Or run this API on the same host/Docker network as that proxy.
#
PROVIDER_BASE_URL=https://domain.com/football/api/v1/h2h/sports

# ── Auth (set both when your plan issues a key) ─────────────────────────────
# PROVIDER_API_KEY     = raw secret or "Bearer <token>" if using Authorization.
# PROVIDER_AUTH_HEADER_NAME = HTTP header name the provider expects.
#
# Examples (uncomment and replace — never commit real secrets):
# PROVIDER_API_KEY=your-secret-or-Bearer-token-here
# PROVIDER_AUTH_HEADER_NAME=x-api-key
#
# PROVIDER_API_KEY=Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6...
# PROVIDER_AUTH_HEADER_NAME=Authorization
#
PROVIDER_API_KEY=
PROVIDER_AUTH_HEADER_NAME=x-api-key

PROVIDER_TIMEOUT_MS=15000
PROVIDER_RETRY_ATTEMPTS=5
PROVIDER_RETRY_DELAY_MS=1000

# ── Alerting (SMTP) ─────────────────────────────────────────────────────────
# Outbound email used for max-retry and schema-mismatch alerts.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=change-me
ALERT_EMAIL_TO=ops@example.com

# ── Request identity headers ──────────────────────────────────────────────────
# The provider mirrors SofaScore's infrastructure — these headers make our
# requests look like normal browser traffic from the SofaScore website.
# Defaults are correct for sportsdata365; only change if ops explicitly asks.
SOFA_REFERER=https://www.sofascore.com
SOFA_ORIGIN=https://www.sofascore.com
SOFA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# ── Sport / API contract ──────────────────────────────────────────────────────
# The default sport used when building API paths.
# Change when you spin up a tennis or basketball variant of this service.
SOFA_DEFAULT_SPORT=football

# Country codes used when fetching "default tournaments per country" priorities.
# These are the markets matchstat.com targets — add/remove as the product grows.
SOFA_CONFIG_COUNTRY_CODES=BD,GB,IN,US,DE,ES,IT,FR,BR

# Page index for team past-events pagination (SofaScore uses 0-based pages).
SOFA_TEAM_EVENTS_PAGE=0

# How many recent seasons to fetch metadata for per tournament.
SOFA_TOURNAMENT_SEASONS_LOOKBACK=2

# Odds provider ID in SofaScore's system (1 = default, shown in URL as /odds/1/…).
SOFA_ODDS_PROVIDER_ID=1

# Lightweight path under PROVIDER_BASE_URL used for the /health provider ping.
SOFA_HEALTH_PROBE_PATH=sport/football/categories/all

# ── Ingestion behaviour ───────────────────────────────────────────────────────
# Pause between sequential provider calls (milliseconds).
# Prevents rate-limiting (429) on burst ingestion.
INGESTION_REQUEST_DELAY_MS=500

# How many calendar days back the historical backfill job should reach.
BACKFILL_DAYS_BACK=365

# Enable the broader all-football tiered ingestion plan.
INGESTION_ENABLE_FULL_FOOTBALL_PLAN=true

# Master switch for all scheduled cron jobs.
INGESTION_ENABLE_SCHEDULED_CRON=true

# Enables high-frequency live / near-live refresh jobs.
INGESTION_ENABLE_LIVE_CRON=true

# Run the bootstrap warmup sequence once after the HTTP server starts.
INGESTION_RUN_BOOTSTRAP_ON_STARTUP=true

# Allow country/tournament registry refresh during startup bootstrap.
INGESTION_ENABLE_REGISTRY_BOOTSTRAP_REFRESH=true

# Keep legacy focused tournament jobs enabled alongside the all-football plan.
# Default false to avoid duplicate provider pressure once the broad plan is on.
INGESTION_ENABLE_FOCUSED_COMPATIBILITY_JOBS=false

# Legacy focused startup mode. Keep false when using the all-football plan.
INGESTION_RUN_FOCUSED_FLOW_ON_STARTUP=false

# Refresh only the latest N historical days during the nightly tier-3 backfill.
INGESTION_NIGHTLY_BACKFILL_DAYS=3

# Persist RUNNING job counters every N provider path attempts.
INGESTION_PROGRESS_FLUSH_EVERY=50

# Mark leftover RUNNING jobs as stale on next boot after an unclean shutdown.
INGESTION_MARK_RUNNING_STALE_ON_STARTUP=true

# ── Snapshot TTL per volatility class (seconds). 0 = never expires (no refetch pressure).
# Cleanup job only deletes expired *live* rows — other types are kept for history.
TTL_LIVE_S=30
TTL_SCHEDULED_S=300
TTL_RECENT_S=3600
TTL_HISTORICAL_S=0
TTL_METADATA_S=0
TTL_IMMUTABLE_S=0

# ── Rate limiting (public API) ────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
